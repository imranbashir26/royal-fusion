NODE_ENV=replace_with_environment_name
PORT=replace_with_backend_port
CLIENT_ORIGIN=replace_with_allowed_frontend_origin

# SERVER-ONLY SECRETS. Never expose these through VITE_ variables.
JWT_SECRET=replace_with_strong_random_secret
ADMIN_SETUP_KEY=replace_with_private_setup_key

# Optional first-run owner creation. Leave blank after setup.
ADMIN_EMAIL=replace_with_initial_owner_email
ADMIN_PASSWORD=replace_with_initial_owner_password
ADMIN_NAME=replace_with_initial_owner_name

# Production migration targets currently checked by the readiness script.
SUPABASE_URL=replace_with_server_supabase_url
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
SANITY_API_TOKEN=replace_with_sanity_server_token

# Optional server integrations.
SENTRY_DSN=replace_with_server_monitoring_dsn
RESEND_API_KEY=replace_with_server_email_api_key

# Optional prototype database override. Keep the live JSON database backend-only.
RF_DB_PATH=replace_with_backend_database_file_path
