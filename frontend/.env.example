VITE_SUPABASE_ANON_KEY=replace_with_public_supabase_anon_key
VITE_SANITY_PROJECT_ID=replace_with_public_sanity_project_id
VITE_SANITY_DATASET=replace_with_public_sanity_dataset
VITE_SANITY_API_VERSION=replace_with_public_sanity_api_version
