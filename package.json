{
  "name": "royal-fusion",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:api": "npm run dev --workspace backend",
    "dev:backend": "npm run dev --workspace backend",
    "dev:full": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build --workspace frontend",
    "lint": "npm run lint --workspace frontend",
    "preview": "npm run preview --workspace frontend",
    "admin:create": "npm run admin:create --workspace backend --",
    "api:smoke": "npm run api:smoke --workspace backend",
    "env:check:prod": "npm run env:check:prod --workspace backend",
    "test:backend": "npm test --workspace backend",
    "test:auth": "npm run test:auth-contracts --workspace backend",
    "test:guest-checkout": "npm run test:guest-checkout --workspace backend",
    "test:auth-foundation": "npm run test:backend"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
